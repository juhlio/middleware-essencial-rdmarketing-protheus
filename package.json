{
  "name": "rest-leads-essencial",
  "version": "1.0.0",
  "description": "REST API para gestão de leads",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/*.spec.js"
    ]
  },
  "nodemonConfig": {
    "ignore": [
      "tests/",
      "node_modules/"
    ],
    "ext": "js,json"
  }
}
