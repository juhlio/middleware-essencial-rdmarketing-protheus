# =============================================================================
# RD STATION (OAuth2 — App Publisher)
# =============================================================================

RD_STATION_CLIENT_ID=seu_client_id_aqui
RD_STATION_CLIENT_SECRET=seu_client_secret_aqui
RD_STATION_REDIRECT_URI=http://localhost:3000/api/auth/callback
RD_STATION_API_URL=https://api.rd.services/platform

# =============================================================================
# SERVIDOR
# =============================================================================

PORT=3000
NODE_ENV=development

# =============================================================================
# BANCO DE DADOS (PostgreSQL)
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=middleware_user
DB_PASSWORD=senha_segura_aqui
DB_NAME=rd_station_middleware

# =============================================================================
# WEBHOOK
# =============================================================================

# Token secreto para validar webhooks do RD Station (recomendado em produção)
# Adicione ?auth_token=ESTE_VALOR na URL do webhook no painel do RD Station
WEBHOOK_SECRET=sua_chave_secreta_webhook

# =============================================================================
# OPCIONAIS
# =============================================================================

LOG_LEVEL=info

# =============================================================================
# PROTHEUS
# =============================================================================

# Token que o Protheus deve enviar em todas as requisições de consulta de leads.
# Header aceito: "Authorization: Bearer <token>" ou "X-API-Key: <token>"
PROTHEUS_API_KEY=chave_secreta_protheus

# =============================================================================
# E-MAIL (SMTP)
# =============================================================================

# Servidor SMTP
SMTP_HOST=mail.seudominio.com.br
# Porta SMTP (587 = TLS/STARTTLS, 465 = SSL)
SMTP_PORT=587
# true para SSL direto (porta 465), false para STARTTLS (porta 587)
SMTP_SECURE=false
# Usuário e senha da conta de envio
SMTP_USER=notificacoes@seudominio.com.br
SMTP_PASS=sua_senha_smtp
# Endereço "De:" do e-mail (padrão: SMTP_USER)
EMAIL_FROM=notificacoes@seudominio.com.br
# Destinatário(s) das notificações — separe múltiplos e-mails por vírgula
NOTIFY_EMAIL_TO=responsavel@empresa.com.br,outro@empresa.com.br
