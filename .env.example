# =============================================================================
# RD STATION
# =============================================================================

# Client ID do App no RD Station App Publisher
RD_STATION_CLIENT_ID=seu_client_id_aqui

# Client Secret do App no RD Station App Publisher
RD_STATION_CLIENT_SECRET=seu_client_secret_aqui

# URL de callback OAuth2 (deve estar cadastrada no App Publisher)
RD_STATION_REDIRECT_URI=http://localhost:3000/api/auth/callback

# URL base da API do RD Station Marketing (não alterar)
RD_STATION_API_URL=https://api.rd.services/platform

# =============================================================================
# SERVIDOR
# =============================================================================

# Porta em que a aplicação vai escutar
PORT=3000

# Ambiente de execução: development | production | test
NODE_ENV=development

# =============================================================================
# BANCO DE DADOS (PostgreSQL)
# =============================================================================

# Host do servidor PostgreSQL
DB_HOST=localhost

# Porta do PostgreSQL (padrão: 5432)
DB_PORT=5432

# Usuário do banco de dados
DB_USER=middleware_user

# Senha do usuário do banco de dados
DB_PASSWORD=senha_segura_aqui

# Nome do banco de dados
DB_NAME=rd_station_middleware

# =============================================================================
# SINCRONIZAÇÃO
# =============================================================================

# Intervalo em minutos entre cada ciclo de sincronização de leads
SYNC_INTERVAL_MINUTES=30

# Quantidade máxima de leads processados por lote em cada sincronização
SYNC_BATCH_SIZE=200

# =============================================================================
# OPCIONAIS
# =============================================================================

# Nível de log da aplicação: error | warn | info | debug
LOG_LEVEL=info

# Chave secreta usada para assinar e verificar tokens JWT
API_KEY_SECRET=chave_secreta_jwt

# =============================================================================
# WEBHOOK
# =============================================================================

# Token secreto para validar webhooks do RD Station (recomendado em produção)
# Adicione ?auth_token=ESTE_VALOR na URL do webhook no painel do RD Station
WEBHOOK_SECRET=sua_chave_secreta_webhook
